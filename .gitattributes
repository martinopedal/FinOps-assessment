# Squad: union merge for append-only team state files
.squad/decisions.md merge=union
.squad/agents/*/history.md merge=union
.squad/log/** merge=union
.squad/orchestration-log/** merge=union

# Auto-generated artefacts whose bytes must match scripts/generate_docs.py
# output regardless of the operator's platform. Without these rules, a
# Windows checkout (core.autocrlf=true on hosted runners) rewrites the
# committed files with CRLF line endings and the freshness gate in
# .github/workflows/docs.yml — which byte-compares the regenerated LF
# output against the working tree — fails on Windows only.
docs/rules.md text eol=lf
examples/demo-report.csv text eol=lf
examples/demo-report.html text eol=lf
examples/demo-report.json text eol=lf
examples/demo-triage.csv text eol=lf
examples/demo-triage.json text eol=lf
examples/focus-aligned.csv text eol=lf
examples/focus-aligned.csv.manifest.json text eol=lf
# Test golden fixtures for the FOCUS-aligned reporter — byte-compared in tests
# 1 & 2 (test_golden_csv_byte_identical / test_golden_manifest_byte_identical).
# Must be LF on all platforms or the comparison fails on Windows-hosted runners.
tests/fixtures/focus_aligned/golden-azure.csv text eol=lf
tests/fixtures/focus_aligned/golden-azure.manifest.json text eol=lf
