tests/fixtures/ps_conformance/demo-report-m365.csv text eol=lf
# Cross-engine conformance golden fixtures (PowerShell Phase 4: GitHub + ADO).
# CSV files are byte-compared in Invoke-FinOpsGitHubAdoRules.Tests.ps1;
# without an LF pin a Windows clone rewrites to CRLF and the byte-compare fails.
tests/fixtures/ps_conformance/demo-report-github.csv text eol=lf
tests/fixtures/ps_conformance/demo-report-ado.csv text eol=lf
# Cross-engine conformance golden fixture (PowerShell Phase 3: Azure).
tests/fixtures/ps_conformance/demo-report-azure.csv text eol=lf

# Repo-wide line-ending policy (issue #81) — pin LF endings for all
# source code, data, and doc files to eliminate spurious whitespace
# warnings on cross-platform contributor edits. Renormalized once at
# commit immediately following this .gitattributes change. Any file NOT
# listed above with specific path is covered here; specific path rules
# (e.g., docs/rules.md, examples/*.json) take precedence per gitattributes
# matching semantics.
*.py text eol=lf
*.json text eol=lf
*.yaml text eol=lf
*.yml text eol=lf
*.md text eol=lf
*.j2 text eol=lf

# PowerShell engine (powershell/**). Pin LF so the Pester version-lock /
# byte-compare tests and PSScriptAnalyzer behave identically on the
# Windows-hosted runner (core.autocrlf=true would otherwise rewrite to
# CRLF). Covers the about-help .txt under powershell/ too.
*.ps1 text eol=lf
*.psm1 text eol=lf
*.psd1 text eol=lf
powershell/**/*.txt text eol=lf
